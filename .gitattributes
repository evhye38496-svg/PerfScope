# Binary files — never apply line-ending conversion
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.svg binary
*.vsix binary
*.gz binary

# Text files — normalize line endings
*.ts text eol=lf
*.js text eol=lf
*.json text eol=lf
*.md text eol=lf
*.html text eol=lf
*.css text eol=lf
*.yml text eol=lf
*.sh text eol=lf
*.ps1 text eol=lf
